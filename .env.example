# Curadenapps Agents — Environment Variables
# Copy to .env and populate. Never commit .env to git.

# ── Claude ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # Claude model access (all agents)

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_API_KEY=                           # ntn_... internal integration token
NOTION_ROOT_DATABASE_ID=86b68fc172dd43ff8ee3219a3a5435f6  # seandunne workspace root

# ── Asana ─────────────────────────────────────────────────────────────────────
ASANA_ACCESS_TOKEN=                       # Personal access token or OAuth
ASANA_PROJECT_GID=                        # BOB App project GID (App Requests is a section within this same project)
ASANA_WEBHOOK_SECRET=                     # HMAC secret for X-Hook-Signature verification

# ── Jira / Atlassian ──────────────────────────────────────────────────────────
# Handled via MCP (mcp__cba144a5-138f-455b-8987-f84b72c3c4e9__)
# No raw token needed for Claude Code sessions

# ── Figma ─────────────────────────────────────────────────────────────────────
FIGMA_API_TOKEN=                          # Personal access token from Figma settings
FIGMA_FILE_KEY=                           # BOB design system file key (from Figma URL)
FIGMA_TEAM_ID=                            # Curaden Figma team ID

# ── Webflow ───────────────────────────────────────────────────────────────────
WEBFLOW_API_TOKEN=                        # Webflow API v2 token
WEBFLOW_SITE_ID=                          # Curaden site ID (from Webflow project settings)
WEBFLOW_BRAND_KIT_COLLECTION_ID=          # Brand Kit CMS collection ID
WEBFLOW_WHATS_NEW_COLLECTION_ID=          # What's New / releases collection ID

# ── GitHub ────────────────────────────────────────────────────────────────────
# Handled via MCP (mcp__github__*)
# GITHUB_WEBHOOK_SECRET=                  # Optional: for verifying GitHub webhook payloads

# ── Agent flags ───────────────────────────────────────────────────────────────
DRY_RUN=true                              # Set to false to enable live Asana/Webflow writes
